PORT=8000
NODE_ENV=development
CORS_ORIGIN=
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prince_esquare

JWT_SECRET=
JWT_EXPIRE=30d

# Required in production (local /uploads is ephemeral on Render/Railway)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@<your_cloud_name>
CLOUDINARY_UPLOAD_PRESET=PRINCE-eSQUIIRE
CLOUDINARY_FOLDER=PRINCE-eSQUIIRE
# Production: server refuses to start without Cloudinary unless STORAGE_ALLOW_LOCAL=true
REQUIRE_CLOUDINARY=true
# Dev only — allow /uploads when Cloudinary unset
STORAGE_ALLOW_LOCAL=true
# Public URL for locally stored images (set on deploy, e.g. https://api.yoursite.com)
API_PUBLIC_URL=
BACKEND_URL=

EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Development only: auto-confirm payments when MPESA_* unset. Must be false in production.
MPESA_DEMO_MODE=true

# Checkout totals (optional overrides)
ORDER_SHIPPING_FLAT=250
ORDER_VAT_RATE=0.16

# On server start: auto-sync ecommerce product links + POS prices (recommended true)
AUTO_BOOTSTRAP=true

# POS & Inventory
ADMIN_EMAIL=
ADMIN_PASSWORD=
INTERNAL_KEY=
FRONTEND_URL=http://localhost:5173
SELLER_EMAIL=
SELLER_PASSWORD=
SELLER_NAME=
# Set PURGE_POS_DEMO=false to keep demo seller during bootstrap
PURGE_POS_DEMO=true

# SMTP (low-stock alerts — aliases for EMAIL_* above)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Prisma (optional if using prisma migrate)
DATABASE_URL=postgresql://postgres:password@localhost:5432/prince_esquare

# Database pool (scale under load)
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_IDLE_MS=30000
DB_POOL_CONNECT_MS=10000
DB_STATEMENT_TIMEOUT_MS=30000
DB_SLOW_QUERY_MS=500

# Logging
LOG_LEVEL=info
LOG_JSON=false

# Rate limiting (set RATE_LIMIT_DISABLED=true to disable in dev)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=15
RATE_LIMIT_PAYMENT_MAX=10
RATE_LIMIT_UPLOAD_MAX=30
RATE_LIMIT_SEARCH_MAX=60
RATE_LIMIT_STRICT_MAX=20

# Production behind reverse proxy (nginx, Render, Railway)
TRUST_PROXY=false
JSON_BODY_LIMIT=2mb
